# E3 Digital — Investor Readiness Assessment
# Copy this to .env.local and fill in all values

# ── Auth (Clerk) ──────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_SECRET_KEY=sk_test_...

# ── Database (Railway PostgreSQL) ─────────────
DATABASE_URL=postgresql://user:password@host:port/dbname

# ── AI Scoring (OpenRouter) ───────────────────
OPENROUTER_API_KEY=sk-or-...
AI_MODEL=anthropic/claude-sonnet-4

# ── Email (SMTP2Go) ───────────────────────────
SMTP2GO_API_KEY=api-...
SMTP2GO_WEBHOOK_TOKEN=your-webhook-bearer-token

# ── CRM (Brevo) ───────────────────────────────
BREVO_API_KEY=xkeysib-...
# List IDs — find in Brevo → Contacts → Lists
BREVO_ASSESSMENT_LIST_ID=0
BREVO_INVESTMENT_READY_LIST_ID=0
BREVO_NEARLY_THERE_LIST_ID=0
BREVO_EARLY_STAGE_LIST_ID=0
BREVO_TOO_EARLY_LIST_ID=0

# ── Bot Prevention (reCAPTCHA v3) ─────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6L...
RECAPTCHA_SECRET_KEY=6L...

# ── Error Monitoring (Sentry) ─────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=e3-digital
SENTRY_PROJECT=investment-readiness

# ── Analytics ─────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...

# ── Booking ───────────────────────────────────
NEXT_PUBLIC_ZOHO_BOOKING_URL=https://...

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://assess.e3digital.net
